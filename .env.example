# Anthropic API — Prosper simulator AI explanations
ANTHROPIC_API_KEY=sk-ant-...

# Next.js — server-side proxy target for /api/welllog/*
# (used by next.config.ts rewrites; not exposed to the browser)
WELLLOG_API_URL=http://localhost:8000

# Optional — call FastAPI directly from the browser instead of the proxy.
# Leave unset to use /api/welllog (recommended for local dev and production).
# NEXT_PUBLIC_WELLLOG_API_URL=http://localhost:8000
